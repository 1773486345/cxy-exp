{
  "schema_version": 1,
  "experiment_name": "patternad_factorial_v2_holdout",
  "description": "Minimal C x D ablation with disjoint-normal-reference context-stratified tail calibration and complementary scoring fixed in A cells.",
  "benchmark": {
    "script": "scripts/run_benchmark.py",
    "config_path": "unfixed_detect_label_multi_config.json",
    "model_name": "PatternAD.PatternAD",
    "evaluation_protocol": "train_calibration",
    "anomaly_ratios": [1.0],
    "calibration_fraction": 0.2,
    "eval_backend": "sequential",
    "num_workers": 1,
    "num_cpus": 3,
    "timeout_seconds": 60000,
    "aggregate_type": "mean",
    "require_model_diagnostics": true,
    "max_scale_boundary_fraction": 0.01
  },
  "default_group": "smoke",
  "development_seeds": [2021, 2022, 2023],
  "confirmation_seeds": [2021, 2022, 2023, 2024, 2025],
  "score_metrics": [
    "auc_pr",
    "VUS_PR",
    "auc_roc",
    "VUS_ROC",
    "R_AUC_PR",
    "R_AUC_ROC"
  ],
  "shared_hyperparameters": {
    "batch_size": 64,
    "d_ff": 256,
    "d_model": 128,
    "dropout": 0.0,
    "e_layers": 2,
    "num_epochs": 30,
    "seq_len": 24,
    "train_mask_ratio": 0.25,
    "train_variable_mask_ratio": 0.15,
    "reconstruction_full_loss_weight": 0.1,
    "reconstruction_transition_loss_weight": 0.0,
    "reconstruction_causal_innovation_loss_weight": 0.0,
    "use_causal_innovation_diagnostics": false,
    "reconstruction_validation_fraction": 0.1,
    "use_context_scale_prior": true,
    "context_scale_floor": 0.05,
    "context_scale_prior_mix": 0.5,
    "context_scale_log_residual_limit": 1.5,
    "context_transition_scale_suppression": 0.0,
    "use_context_scale_normalization": true,
    "use_context_transition_scale_prior": true,
    "context_transition_scale_floor": 0.05,
    "context_transition_scale_prior_mix": 0.5,
    "context_transition_scale_log_residual_limit": 1.5,
    "score_mask_ratio": 0.3333333333333333,
    "pattern_score_components": ["raw"],
    "pattern_score_aggregation": "mean",
    "pattern_score_use_calibration": false,
    "pattern_score_contextual_calibration_bins": 4,
    "pattern_score_contextual_calibration_min_bin_size": 128,
    "pattern_score_contextual_calibration_shrinkage": 128.0,
    "pattern_score_contextual_calibration_max_cells": 500000,
    "pattern_score_reference_fraction": 0.1,
    "parallel_strategy": "DP"
  },
  "variants": {
    "A00": {
      "description": "C0/D0/M1: learned constant-context deterministic complementary-mask control.",
      "factors": {"context": "C0", "distribution": "D0", "mask": "M1"},
      "hyperparameters": {
        "use_context_conditioning": false,
        "reconstruction_distribution": "mse",
        "pattern_score_mode": "raw",
        "use_conditional_scoring": true
      }
    },
    "A10": {
      "description": "C1/D0/M1: visible context with deterministic complementary scoring.",
      "factors": {"context": "C1", "distribution": "D0", "mask": "M1"},
      "hyperparameters": {
        "use_context_conditioning": true,
        "reconstruction_distribution": "mse",
        "pattern_score_mode": "raw",
        "use_conditional_scoring": true
      }
    },
    "A01": {
      "description": "C0/D1/M1: learned constant-context Gaussian with normal-only scale-stratified empirical tail calibration.",
      "factors": {"context": "C0", "distribution": "D1", "mask": "M1"},
      "hyperparameters": {
        "use_context_conditioning": false,
        "reconstruction_distribution": "gaussian",
        "reconstruction_transition_loss_weight": 0.0,
        "pattern_score_mode": "contextual_tail_probability",
        "use_conditional_scoring": true
      }
    },
    "A11": {
      "description": "C1/D1/M1: visible context and heteroscedastic Gaussian with normal-only scale-stratified empirical tail calibration.",
      "factors": {"context": "C1", "distribution": "D1", "mask": "M1"},
      "hyperparameters": {
        "use_context_conditioning": true,
        "reconstruction_distribution": "gaussian",
        "reconstruction_transition_loss_weight": 0.0,
        "pattern_score_mode": "contextual_tail_probability",
        "use_conditional_scoring": true
      }
    },
    "B00": {
      "description": "C0/D0/M0: constant-context unmasked diagnostic paired with A00.",
      "factors": {"context": "C0", "distribution": "D0", "mask": "M0"},
      "hyperparameters": {
        "use_context_conditioning": false,
        "reconstruction_distribution": "mse",
        "pattern_score_mode": "raw",
        "use_conditional_scoring": false
      }
    },
    "B11": {
      "description": "C1/D1/M0: unmasked heteroscedastic Gaussian diagnostic paired with A11.",
      "factors": {"context": "C1", "distribution": "D1", "mask": "M0"},
      "hyperparameters": {
        "use_context_conditioning": true,
        "reconstruction_distribution": "gaussian",
        "reconstruction_transition_loss_weight": 0.0,
        "pattern_score_mode": "tail_probability",
        "use_conditional_scoring": false
      }
    }
  },
  "comparisons": [
    {"name": "full_vs_baseline", "lhs": "A11", "rhs": "A00"},
    {"name": "context_at_D0", "lhs": "A10", "rhs": "A00"},
    {"name": "context_at_D1", "lhs": "A11", "rhs": "A01"},
    {"name": "distribution_at_C0", "lhs": "A01", "rhs": "A00"},
    {"name": "distribution_at_C1", "lhs": "A11", "rhs": "A10"},
    {"name": "conditional_mask_at_C0_D0", "lhs": "A00", "rhs": "B00"},
    {"name": "conditional_mask_at_C1_D1", "lhs": "A11", "rhs": "B11"}
  ]
}
